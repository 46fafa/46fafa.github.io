    &gt;anki&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;https://github.com/FooSoft/anki-connect&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;anki-connect&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;https://github.com/kerrickstaley/genanki&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;genanki&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;https://github.com/trentm/python-markdown2&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;markdown2&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
